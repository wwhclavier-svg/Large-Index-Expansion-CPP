ideal gbs=simplify(gb,`sim`);
`outvars`"
];
rule=<|"char"->char,
"vars"->StringJoin@Riffle[varrep[[All,2]],","],
"order"->order,
"degbound"->degBound,
"ideal"->ideal,
"sim"->OptionValue["SimplificationRules"],
"outvars"->{"gbs","lt"}
|>;

