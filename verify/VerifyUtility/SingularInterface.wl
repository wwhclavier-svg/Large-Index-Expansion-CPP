Options[SingularGroebnerBasisF5]=Join[Options[SingularGroebnerBasis],{"morder"->0,"rorder"->1}];
SingularGroebnerBasisF5[ideal_List,varorder_List,OptionsPattern[]]:=Module[{degBound=OptionValue["degBound"],morder=OptionValue["morder"],rorder=OptionValue["rorder"],
order,varrep,posrep,windowsQ,dir,dirCode,template,rule,gb,liftmat,liftQ=OptionValue["LiftMatrix"],char=OptionValue[Modulus],mo=OptionValue["MonomialOrder"]},

