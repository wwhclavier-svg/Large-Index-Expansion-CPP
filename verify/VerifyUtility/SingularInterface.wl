(* ::Subsection:: *)
(*5.4 SingularPrimaryDecomposition*)


(* ::Input::Initialization:: *)
SingularPrimaryDecomp//ClearAll;
SingularPrimaryDecomp::usage="SingularPrimaryDecomp[ideal,varorder,posorder,OptionsPattern[]] gives the primary decomposition for the ideal 'ideal' using Singular.
SingularGroebnerBasis[module,varorder,posorder,OptionsPattern[]] gives a Groebner basis for the module 'module' using Singular. Here, 'posorder' are basis of ordered positions, and different positions in 'module' are summed over.  
Term orderings are defined by  SingularRingDeclaration[varorder,posorder";
Options[SingularPrimaryDecomp]={"SimplificationRules"->34,"PositionOverTerm"->False,"WithDimension"->True,"MonomialOrder"->"dp",Modulus->0};

SingularPrimaryDecomp[ideal_List,varorder_List,OptionsPattern[]]:=Module[{order,varrep,posrep,windowsQ,dir,dirCode,template,rule,gb,liftmat,primelist,npoly,dimlist,dimQ=OptionValue["WithDimension"],char=OptionValue[Modulus]},

{order,varrep,posrep}=SingularRingDeclaration[varorder,{"e1"},"PositionOverTerm"->OptionValue["PositionOverTerm"],"VariableName"->"x","MonomialOrder"->OptionValue["MonomialOrder"]];

template = StringTemplate[
"
LIB \"primdec.lib\";
ring r = `char`, (`vars`), (`order`);
option(prot);
ideal I=`ideal`;
list pr=primdecGTZE(I);
list prr,rdim,npoly=list(),list(),list();
for(int i=1; i<=size(pr); i=i+1)
{
pr[i][2]=groebner(pr[i][2]);
prr=prr+list(groebner(pr[i][2])); 
rdim=rdim+list(dim(pr[i][2]));
npoly=npoly+list(size(pr[i][2]));
};
`outvars`"
];
rule=<|"char"->char,
"vars"->StringJoin@Riffle[varrep[[All,2]],","],
"order"->order,
"ideal"->ideal,
"sim"->OptionValue["SimplificationRules"],
"outvars"->{"prr","npoly","rdim"}
|>;

{primelist,npoly,dimlist}=SingularRun[template,rule,"Replacement"->Join[posrep,varrep]];
primelist=primelist[[#]]&/@(Table[Range[If[i>1,#[[i-1]],0]+1,#[[i]]],{i,Length@npoly}]&@Table[Total@npoly[[1;;i]],{i,Length@npoly}]);
If[dimQ,{primelist,dimlist},primelist]
];


SingularPrimaryDecompLex//ClearAll;
SingularPrimaryDecompLex::usage="SingularPrimaryDecomp[ideal,varorder,posorder,OptionsPattern[]] gives the primary decomposition for the ideal 'ideal' using Singular.
SingularGroebnerBasis[module,varorder,posorder,OptionsPattern[]] gives a Groebner basis for the module 'module' using Singular. Here, 'posorder' are basis of ordered positions, and different positions in 'module' are summed over.  
Term orderings are defined by  SingularRingDeclaration[varorder,posorder";
Options[SingularPrimaryDecompLex]={"SimplificationRules"->34,"PositionOverTerm"->False,"WithDimension"->True,"MonomialOrder"->"lp",Modulus->0};

SingularPrimaryDecompLex[ideal_List,varorder_List,OptionsPattern[]]:=Module[{orderlex,order,varrep,posrep,windowsQ,dir,dirCode,template,rule,gb,liftmat,primelist,npoly,dimlist,dimQ=OptionValue["WithDimension"],char=OptionValue[Modulus]},

(* Empty varorder guard: ideal with no variables, handle without Singular *)
If[varorder==={},
	If[AllTrue[ideal, #===0&],
		If[dimQ, {{{0}},{0}}, {{0}}],
		If[dimQ, {{{1}},{-1}}, {{1}}]
	]//Return
];

{order,varrep,posrep}=SingularRingDeclaration[varorder,{"e1"},"PositionOverTerm"->OptionValue["PositionOverTerm"],"VariableName"->"x","MonomialOrder"->"dp"];
orderlex=SingularRingDeclaration[varorder,{"e1"},"PositionOverTerm"->OptionValue["PositionOverTerm"],"VariableName"->"x","MonomialOrder"->"lp"][[1]];


template = StringTemplate[
"
LIB \"primdec.lib\";
ring r = `char`, (`vars`), (`order`);
option(prot);
ideal I=`ideal`;
list pr0=primdecGTZE(I);
ring s = `char`, (`vars`), (`orderlex`);
list pr = imap(r,pr0);
list prr,rdim,npoly=list(),list(),list();
for(int i=1; i<=size(pr); i=i+1)
{
pr[i][2]=groebner(pr[i][2]);
prr=prr+list(groebner(pr[i][2])); 
rdim=rdim+list(dim(pr[i][2]));
npoly=npoly+list(size(pr[i][2]));
};
`outvars`"
];
rule=<|"char"->char,
"vars"->StringJoin@Riffle[varrep[[All,2]],","],
"order"->order,
"orderlex"->orderlex,
"ideal"->ideal,
"sim"->OptionValue["SimplificationRules"],
"outvars"->{"prr","npoly","rdim"}
|>;

{primelist,npoly,dimlist}=SingularRun[template,rule,"Replacement"->Join[posrep,varrep]];
primelist=primelist[[#]]&/@(Table[Range[If[i>1,#[[i-1]],0]+1,#[[i]]],{i,Length@npoly}]&@Table[Total@npoly[[1;;i]],{i,Length@npoly}]);
If[dimQ,{primelist,dimlist},primelist]
];


(* ::Subsection:: *)
(*5.5 SingularMinAssPrime*)


SingularMinAssPrime::usage="SingularMinAssPrim[ideal,varorder,OptionsPattern[]] gives the primary decomposition for the ideal 'ideal' using Singular.
SingularGroebnerBasis[module,varorder,posorder,OptionsPattern[]] gives a Groebner basis for the module 'module' using Singular. Here, 'posorder' are basis of ordered positions, and different positions in 'module' are summed over.  
Term orderings are defined by  SingularRingDeclaration[varorder,posorder].";
Options[SingularMinAssPrime]={"SimplificationRules"->34,"PositionOverTerm"->False,"WithDimension"->True,Modulus->0,"MonomialOrder"->"dp"};

SingularMinAssPrime[ideal_List,varorder_List,OptionsPattern[]]:=Module[{order,varrep,posrep,windowsQ,dir,dirCode,template,rule,gb,liftmat,primelist,npoly,dimlist,dimQ=OptionValue["WithDimension"],char=OptionValue[Modulus]},

(* Empty varorder guard: ideal with no variables, handle without Singular *)
If[varorder==={},
	If[AllTrue[ideal, #===0&],
		If[dimQ, {{{0}},{0}}, {{0}}],
		If[dimQ, {{{1}},{-1}}, {{1}}]
	]//Return
];

{order,varrep,posrep}=SingularRingDeclaration[varorder,{"e1"},"PositionOverTerm"->OptionValue["PositionOverTerm"],"VariableName"->"x","MonomialOrder"->OptionValue["MonomialOrder"]];

template = StringTemplate[
"
LIB \"primdec.lib\";
ring r = `char`, (`vars`), (`order`);
option(prot);
ideal I=`ideal`;
list minass = minAssGTZ(I);
list plist,rdim,npoly=list(),list(),list(); 
for(int i=1; i<=size(minass); i=i+1)
{ 
plist = plist+list(minass[i]); 
rdim=rdim+list(dim(minass[i]));
npoly=npoly+list(size(minass[i]));
};
`outvars`"
];
rule=<|"char"->char,
"vars"->StringJoin@Riffle[varrep[[All,2]],","],
"order"->order,
"ideal"->ideal,
"outvars"->{"plist","npoly","rdim"}
|>;

{primelist,npoly,dimlist}=SingularRun[template,rule,"Replacement"->Join[posrep,varrep]];
primelist=primelist[[#]]&/@(Table[Range[If[i>1,#[[i-1]],0]+1,#[[i]]],{i,Length@npoly}]&@Table[Total@npoly[[1;;i]],{i,Length@npoly}]);
If[dimQ,{primelist,dimlist},primelist]
];


