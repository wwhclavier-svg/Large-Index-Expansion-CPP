gb
];


Options[SingularGroebnerBasisSlimgb]=Options[SingularGroebnerBasis];
SingularGroebnerBasisSlimgb[ideal_List,varorder_List,OptionsPattern[]]:=Module[{degBound=OptionValue["degBound"],order,varrep,posrep,windowsQ,dir,dirCode,template,rule,gb,liftmat,liftQ=OptionValue["LiftMatrix"],char=OptionValue[Modulus],mo=OptionValue["MonomialOrder"]},

{order,varrep,posrep}=SingularRingDeclaration[varorder,{e},"PositionOverTerm"->OptionValue["PositionOverTerm"],"VariableName"->"x","MonomialOrder"->mo];

template = StringTemplate[
"ring r = `char`, (`vars`), (`order`);
degBound = `degbound`;
option(prot);
ideal m=`ideal`;
