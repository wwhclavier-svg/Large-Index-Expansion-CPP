   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Avar", "->", "\[IndentingNewLine]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
