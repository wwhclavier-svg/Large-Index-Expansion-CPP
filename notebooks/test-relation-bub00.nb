              RowBox[{
              "regionInfo", "[", "\"\<MonomialBasisMatrix\>\"", "]"}]}], ",", 
             
             RowBox[{"Values", "[", "#", "]"}]}], "}"}], "&"}]}], "//", 
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "i"}], "]"}], "]"}], 
