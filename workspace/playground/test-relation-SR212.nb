Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AMatrixRule", "[", 
    RowBox[{"regionInfo_", ",", "Alist_", ",", "modulus_"}], "]"}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Avar", "->", "\[IndentingNewLine]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Avar", "/.", 
             RowBox[{"regionInfo", "[", "\"\<VarRule\>\"", "]"}]}], ")"}], "//", 
           RowBox[{
            RowBox[{"monomialRulesPower", "[", 
             RowBox[{"#", ",", 
              RowBox[{"regionInfo", "[", "\"\<VarIndep\>\"", "]"}]}], "]"}], 
            "&"}]}], "//", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"Keys", "[", "#", "]"}], "/.", 
              RowBox[{
              "regionInfo", "[", "\"\<MonomialBasisMatrix\>\"", "]"}]}], ",", 
             
             RowBox[{"Values", "[", "#", "]"}]}], "}"}], "&"}]}], "//", 
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "i"}], "]"}], "]"}], 
             RowBox[{"#", "[", 
              RowBox[{"[", 
               RowBox[{"2", ",", "i"}], "]"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", 
              RowBox[{"Length", "@", 
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}]}], "]"}], "&"}]}], "//", 
        RowBox[{
         RowBox[{"PolynomialMod", "[", 
          RowBox[{"#", ",", "modulus"}], "]"}], "&"}]}], ")"}]}], ",", 
     RowBox[{"{", 
