Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"integrals", " ", "are", " ", "expressed", " ", "by", " ", 
    RowBox[{"\"\<j\>\"", "[", 
     RowBox[{"a1", ",", "a2", ",", "..."}], "]"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"seriesVerify", "[", 
     RowBox[{
     "AllRelations_", ",", "regionList_", ",", "seriesList_", ",", "vlist_", 
      ",", "Alist_", ",", "modulus_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "MatrixPowerMod", ",", "DotMod", ",", "rel0", ",", "rel", ",", "level",
         ",", "degree", ",", "varRule", ",", "limitSector", ",", "regionInfo",
         ",", "AMatrix", ",", "AMatInv", ",", "jsvar", ",", "relkey", ",", 
        "relval", ",", "result", ",", "\[IndentingNewLine]", "verifyResult"}],
        "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"MatrixPowerMod", "[", 
         RowBox[{"matrix_", ",", "matinv_", ",", "power_", ",", "mod_"}], 
         "]"}], ":=", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "}"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"power", ">=", "0"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Nest", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"PolynomialMod", "[", 
                RowBox[{
                 RowBox[{"Dot", "[", 
                  RowBox[{"matrix", ",", "#"}], "]"}], ",", "mod"}], "]"}], 
               "&"}], ",", 
              RowBox[{"IdentityMatrix", "@", 
               RowBox[{"Length", "[", "matrix", "]"}]}], ",", "power"}], 
             "]"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Nest", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"PolynomialMod", "[", 
                RowBox[{
                 RowBox[{"Dot", "[", 
                  RowBox[{"matinv", ",", "#"}], "]"}], ",", "mod"}], "]"}], 
               "&"}], ",", 
              RowBox[{"IdentityMatrix", "@", 
               RowBox[{"Length", "[", "matrix", "]"}]}], ",", 
              RowBox[{"-", "power"}]}], "]"}]}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"DotMod", "[", 
         RowBox[{"matList_", ",", "mod_"}], "]"}], ":=", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"res", "=", 
            RowBox[{"IdentityMatrix", "@", 
             RowBox[{"Length", "[", 
              RowBox[{"matList", "[", 
               RowBox[{"[", 
                RowBox[{"-", "1"}], "]"}], "]"}], "]"}]}]}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"res", "=", 
              RowBox[{"PolynomialMod", "[", 
               RowBox[{
                RowBox[{"Dot", "[", 
                 RowBox[{
                  RowBox[{"matList", "[", 
                   RowBox[{"[", 
                    RowBox[{"-", "i"}], "]"}], "]"}], ",", "res"}], "]"}], 
                ",", "mod"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", 
               RowBox[{"Length", "@", "matList"}]}], "}"}]}], "]"}], ";", 
           "res"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"verifyResult", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"level", ",", "degree"}], "}"}], "=", "key"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"AllRelations", "[", "key", "]"}], "==", 
              RowBox[{"{", "}"}]}], ",", 
             RowBox[{"{", "}"}], ",", "\n", 
             RowBox[{
              RowBox[{"rel0", "=", 
               RowBox[{
                RowBox[{"AllRelations", "[", "key", "]"}], "/.", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"\"\<j\>\"", "[", "a__", "]"}], ":>", 
                  RowBox[{"js", "@@", 
                   RowBox[{"(", 
                    RowBox[{"vlist", "-", 
                    RowBox[{"{", "a", "}"}]}], ")"}]}]}], "}"}]}]}], ";", 
              "\n", "\[IndentingNewLine]", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"regionInfo", "=", 
                  RowBox[{"regionList", "[", 
                   RowBox[{"[", "r", "]"}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"varRule", ",", "limitSector"}], "}"}], "=", 
                  RowBox[{"regionInfo", "//", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"#", "[", "\"\<VarRule\>\"", "]"}], ",", 
                    RowBox[{"#", "[", "\"\<LimitSector\>\"", "]"}]}], "}"}], 
                    "&"}]}]}], ";", "\[IndentingNewLine]", 
                 RowBox[{"rel", "=", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"rel0", "/", 
                    RowBox[{"n", "^", "degree"}]}], ")"}], "/.", 
                   RowBox[{"Thread", "[", 
                    RowBox[{"vlist", "->", 
                    RowBox[{"vlist", "+", 
                    RowBox[{"limitSector", "*", "n"}]}]}], "]"}]}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"AMatrix", "=", 
                  RowBox[{"Table", "[", "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"Avar", "/.", 
                    RowBox[{"regionInfo", "[", "\"\<VarRule\>\"", "]"}]}], 
                    ")"}], "//", 
                    RowBox[{
                    RowBox[{"monomialRulesPower", "[", 
                    RowBox[{"#", ",", 
                    RowBox[{"regionInfo", "[", "\"\<VarIndep\>\"", "]"}]}], 
                    "]"}], "&"}]}], "//", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Keys", "[", "#", "]"}], "/.", 
                    RowBox[{
                    "regionInfo", "[", "\"\<MonomialBasisMatrix\>\"", "]"}]}],
                     ",", 
                    RowBox[{"Values", "[", "#", "]"}]}], "}"}], "&"}]}], "//", 
                    RowBox[{
                    RowBox[{"Sum", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"#", "[", 
                    RowBox[{"[", 
                    RowBox[{"1", ",", "i"}], "]"}], "]"}], 
                    RowBox[{"#", "[", 
                    RowBox[{"[", 
                    RowBox[{"2", ",", "i"}], "]"}], "]"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"i", ",", 
                    RowBox[{"Length", "@", 
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}]}], "]"}], 
                    "&"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"Avar", ",", "Alist"}], "}"}]}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"AMatInv", "=", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{"Inverse", "[", 
                    RowBox[{"Avar", ",", 
                    RowBox[{"Modulus", "->", "modulus"}]}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"Avar", ",", "AMatrix"}], "}"}]}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"relkey", "=", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Reverse", "@", 
                    RowBox[{"SortBy", "[", 
                    RowBox[{"#", ",", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Total", "[", 
                    RowBox[{"List", "@@", "#"}], "]"}], ",", "#"}], "}"}], 
                    "&"}]}], "]"}]}], "&"}], "@", 
                   RowBox[{"DeleteDuplicates", "@", 
                    RowBox[{"Cases", "[", 
                    RowBox[{"rel", ",", "_js", ",", "Infinity"}], "]"}]}]}]}],
                  ";", "\[IndentingNewLine]", 
                 RowBox[{"relval", "=", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"Coefficient", "[", 
                    RowBox[{"#", ",", "relkey"}], "]"}], "&"}], "/@", 
                   "rel"}]}], ";", 
                 RowBox[{"relkey", "=", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"List", "@@", "#"}], "&"}], "/@", "relkey"}]}], 
                 ";", "\[IndentingNewLine]", 
                 RowBox[{"relkey", "=", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"PolynomialMod", "[", 
                    RowBox[{"#", ",", "modulus"}], "]"}], "&"}], "@", 
                    RowBox[{"Dot", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"DotMod", "[", 
                    RowBox[{"#", ",", "modulus"}], "]"}], "&"}], "@", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"MatrixPowerMod", "[", 
                    RowBox[{
                    RowBox[{"AMatrix", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", 
                    RowBox[{"AMatInv", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
                    RowBox[{"-", 
                    RowBox[{"akey", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], ",", "modulus"}], "]"}],
                     ",", 
                    RowBox[{"{", 
                    RowBox[{"i", ",", 
                    RowBox[{"Length", "@", "AMatrix"}]}], "}"}]}], "]"}]}], 
                    ")"}], ",", 
                    RowBox[{"(", 
                    RowBox[{"Sum", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"1", "/", 
                    RowBox[{"n", "^", "k"}]}], ")"}], 
                    RowBox[{"seriesList", "[", 
                    RowBox[{"[", 
                    RowBox[{"r", ",", 
                    RowBox[{"k", "+", "1"}]}], "]"}], "]"}]}], "/.", 
                    RowBox[{"Thread", "[", 
                    RowBox[{"vlist", " ", "->", " ", 
                    RowBox[{"vlist", "-", "akey"}]}], "]"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"k", ",", "0", ",", "order"}], "}"}]}], "]"}], 
                    ")"}]}], "]"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"akey", ",", "relkey"}], "}"}]}], "]"}]}], ";", 
                 RowBox[{"result", "=", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{
                    RowBox[{"Sum", "[", 
                    RowBox[{
                    RowBox[{"PolynomialMod", "[", 
                    RowBox[{
                    RowBox[{"Expand", "[", 
                    RowBox[{
                    RowBox[{"relkey", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], 
                    RowBox[{"relval", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", ",", "j"}], "]"}], "]"}]}], "]"}], ",", 
                    "modulus"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"j", ",", 
                    RowBox[{"Length", "@", "relkey"}]}], "}"}]}], "]"}], "//", 
                    RowBox[{
                    RowBox[{"CoefficientList", "[", 
                    RowBox[{"#", ",", 
                    RowBox[{"1", "/", "n"}], ",", 
                    RowBox[{"order", "+", "1"}]}], "]"}], "&"}]}], "//", 
                    RowBox[{
                    RowBox[{"PolynomialMod", "[", 
                    RowBox[{"#", ",", "modulus"}], "]"}], "&"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"k", ",", 
                    RowBox[{"Length", "@", "rel"}]}], "}"}]}], "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"Print", "[", 
                  RowBox[{
                  "\"\<(lev,deg)=(\>\"", ",", "level", ",", "\"\<,\>\"", ",", 
                   "degree", ",", "\"\<)\>\"", ",", "\"\<    sector=\>\"", 
                   ",", "limitSector", ",", "\"\<  (reg-\>\"", ",", "r", ",", 
                   "\"\<) : \>\"", ",", 
                   RowBox[{"result", "//", "MatrixForm"}]}], "]"}], ";", 
                 "\[IndentingNewLine]", "result"}], "\[IndentingNewLine]", 
                ",", 
                RowBox[{"{", 
                 RowBox[{"r", ",", 
                  RowBox[{"Length", "@", "regionList"}]}], "}"}]}], "]"}]}]}],
             "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"key", ",", 
            RowBox[{"Keys", "[", "AllRelations", "]"}]}], "}"}]}], 
         "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
 InitializationCell->False,
