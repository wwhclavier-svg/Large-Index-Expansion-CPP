              RowBox[{"Keys", "[", "#", "]"}], "/.", 
              RowBox[{
              "regionInfo", "[", "\"\<MonomialBasisMatrix\>\"", "]"}]}], ",", 
             
             RowBox[{"Values", "[", "#", "]"}]}], "}"}], "&"}]}], "//", 
         RowBox[{
          RowBox[{"Sum", "[", 
           RowBox[{
