                RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}]}], "]"}], "&"}]}], "//", 
        RowBox[{
         RowBox[{"PolynomialMod", "[", 
          RowBox[{"#", ",", "modulus"}], "]"}], "&"}]}], ")"}]}], ",", 
