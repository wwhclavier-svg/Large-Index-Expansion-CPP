Cell[BoxData[
 RowBox[{
  RowBox[{"polyVectorSort", "[", 
   RowBox[{"polyVecList_", ",", "vlist_"}], "]"}], ":=", 
  RowBox[{"Reverse", "@", 
   RowBox[{"SortBy", "[", 
    RowBox[{"polyVecList", ",", 
     RowBox[{
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"i", "=", "1"}], "}"}], ",", 
        RowBox[{
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "==", "0"}], ",", 
           RowBox[{"i", "++"}]}], "]"}], ";", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "<=", 
            RowBox[{"Length", "@", 
             RowBox[{"polyVecList", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"Exponent", "[", 
             RowBox[{
              RowBox[{"LT", "[", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], ",", "vlist", ",", 
                "\"\<dp\>\""}], "]"}], ",", "vlist"}], "]"}], "//", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "i"}], ",", 
               RowBox[{"Total", "[", "#", "]"}], ",", 
               RowBox[{"-", 
                RowBox[{"Reverse", "@", "#"}]}]}], "}"}], "&"}]}], ",", "0"}],
           "]"}]}]}], "]"}], "&"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9877370582221823`*^9, 3.987737106912364*^9}},
 CellLabel->
