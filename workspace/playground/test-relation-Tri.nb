     RowBox[{"AllRelationsToNuFormat", "[", 
      RowBox[{"$AllRelations", ",", "j", ",", "vlist"}], "]"}], "//", 
     RowBox[{
      RowBox[{"Association", "@", 
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"Keys", "[", "#", "]"}], "->", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", "\"\<Relations\>\"", "]"}], "&"}], "/@", 
           RowBox[{"Values", "[", "#", "]"}]}], ")"}]}], "]"}]}], "&"}]}], "//", 
    RowBox[{
     RowBox[{"Collect", "[", 
      RowBox[{
       RowBox[{"#", "/.", 
        RowBox[{
         RowBox[{"j", "[", "a__", "]"}], ":>", 
         RowBox[{"\"\<j\>\"", "[", "a", "]"}]}]}], ",", 
       RowBox[{"b_", "/;", 
        RowBox[{
         RowBox[{"Head", "[", "b", "]"}], "==", "\"\<j\>\""}]}]}], "]"}], 
