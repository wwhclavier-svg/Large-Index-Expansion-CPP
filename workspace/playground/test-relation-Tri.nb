   RowBox[{"\<\"KinematicRules\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["p1", "2"], "\[Rule]", "s1"}], ",", 
      RowBox[{
       SuperscriptBox["p2", "2"], "\[Rule]", "s2"}], ",", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"p1", "+", "p2"}], ")"}], "2"], "\[Rule]", "s3"}], ",", 
      RowBox[{
       RowBox[{"p1", " ", "p2"}], "\[Rule]", 
       RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "s1"}], "-", "s2", "+", "s3"}], ")"}]}]}]}], "}"}]}], 
   ",", 
