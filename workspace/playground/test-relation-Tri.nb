          RowBox[{"0", ",", "2"}], "]"}]}], "]"}]}]}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"g", "[", "a__", "]"}], ":>", 
      RowBox[{"\"\<j\>\"", "[", "a", "]"}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"relcppData", "=", 
   RowBox[{"Get", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{"$ProjectDir", ",", "\"\<relations\>\"", ",", 
       RowBox[{
