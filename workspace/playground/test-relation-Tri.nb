Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Description\"\>", 
    "\[Rule]", "\<\"1-loop triangle, 3 props, s1=3,s2=8,s3=0\"\>"}], ",", 
   RowBox[{"\<\"Propagators\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["k1", "2"], "-", "msq"}], ",", 
      RowBox[{
       RowBox[{"-", "msq"}], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"k1", "-", "p1"}], ")"}], "2"]}], ",", 
      RowBox[{
       RowBox[{"-", "msq"}], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"k1", "+", "p2"}], ")"}], "2"]}]}], "}"}]}], ",", 
   RowBox[{"\<\"LoopMomenta\"\>", "\[Rule]", 
